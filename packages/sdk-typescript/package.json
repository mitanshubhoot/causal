{
  "name": "@causal/sdk",
  "version": "0.1.0",
  "description": "Causal SDK — automatic provenance capture for TypeScript AI agent projects",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
