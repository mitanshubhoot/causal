{
  "name": "causal-mcp",
  "version": "0.1.0",
  "description": "Causal MCP server for Claude Code — automatic provenance capture",
  "type": "module",
  "bin": {
    "causal-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@causal/sdk": "workspace:*",
    "@causal/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "uuidv7": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
