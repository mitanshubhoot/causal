# ── Database ──────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=causal_dev_password

POSTGRES_URL=postgresql://causal:causal_dev_password@localhost:5432/causal
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=causal
POSTGRES_USER=causal
POSTGRES_PASSWORD=causal_dev_password

REDIS_URL=redis://localhost:6379

# ── Object Storage ────────────────────────────────────────────────
# Use S3-compatible: AWS S3, Cloudflare R2, or MinIO (local dev)
S3_BUCKET=causal-snapshots
S3_REGION=auto
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── LLM APIs ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Auth (Clerk) ──────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Integrations ──────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
PAGERDUTY_WEBHOOK_SECRET=
SENTRY_WEBHOOK_SECRET=
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# ── App ───────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
RCA_SERVICE_URL=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:3001
APP_URL=http://localhost:3000

# ── Feature flags ─────────────────────────────────────────────────
ENABLE_VECTOR_EMBEDDINGS=false
ENABLE_SLACK_NOTIFICATIONS=true
MIN_CONFIDENCE_THRESHOLD=0.5
